  @@map("sessions")
}

model Verification {
  id         String   @id
  identifier String
  value      String   @unique @map("token")
  expiresAt  DateTime @map("expires")
  createdAt  DateTime @default(now()) @db.Timestamptz(6) @map("created_at")
  updatedAt  DateTime @db.Timestamptz(6) @map("updated_at")

  @@index([identifier])
  @@map("verification_tokens")
}
