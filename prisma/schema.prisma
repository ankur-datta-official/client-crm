model Account {
  id                    String    @id
  userId                String    @db.Uuid
  accountId             String    @map("providerAccountId")
  providerId            String    @map("provider")
  accessToken           String?   @db.Text @map("access_token")
  refreshToken          String?   @db.Text @map("refresh_token")
  accessTokenExpiresAt  DateTime? @db.Timestamptz(6) @map("access_token_expires_at")
  refreshTokenExpiresAt DateTime? @db.Timestamptz(6) @map("refresh_token_expires_at")
  scope                 String?
  idToken               String?   @db.Text @map("id_token")
  password              String?   @db.Text
  createdAt             DateTime  @default(now()) @db.Timestamptz(6) @map("created_at")
  updatedAt             DateTime  @db.Timestamptz(6) @map("updated_at")
