model WalletTransaction {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id    String    @db.Uuid
  user_id            String    @db.Uuid
  transaction_type   String
  action_key         String
  points_delta       Int
  balance_after      Int
  company_id         String?   @db.Uuid
  followup_id        String?   @db.Uuid
  challenge_id       String?   @db.Uuid
  reward_id          String?   @db.Uuid
  source_record_id   String?   @db.Uuid
  source_record_type String?
  idempotency_key    String
  metadata           Json      @default("{}")
  created_by         String?   @db.Uuid
  created_at         DateTime  @default(now()) @db.Timestamptz(6)
  organization       Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  user               User      @relation("WalletTransactionUser", fields: [user_id], references: [id], onDelete: Cascade)
  company            Company?  @relation("WalletTransactionCompany", fields: [company_id], references: [id], onDelete: SetNull)
  followup           Followup? @relation("WalletTransactionFollowup", fields: [followup_id], references: [id], onDelete: SetNull)
  challenge          ChallengeTemplate? @relation("WalletTransactionChallenge", fields: [challenge_id], references: [id], onDelete: SetNull)
  reward             RewardCatalog? @relation("WalletTransactionReward", fields: [reward_id], references: [id], onDelete: SetNull)
  createdBy          User?     @relation("WalletTransactionCreatedBy", fields: [created_by], references: [id], onDelete: SetNull)
  challengeProgressBonuses UserChallengeProgress[] @relation("ChallengeProgressBonusAward")
  scoringLogs        ScoringActivityLog[]

  @@index([organization_id, user_id, created_at(sort: Desc)])
  @@unique([organization_id, idempotency_key])
  @@map("wallet_transactions")
}

