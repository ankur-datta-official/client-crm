generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                                  String                     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id                     String?                    @db.Uuid
  email                               String                     @unique
  emailVerified                       Boolean                    @default(false) @map("auth_email_verified")
  legacy_email_verified               DateTime?                  @map("email_verified") @db.Timestamptz(6)
  name                                String?                    @map("full_name")
  image                               String?                    @map("avatar_url")
  password_hash                       String?
  job_title                           String?
  department                          String?
  phone                               String?
  manager_user_id                     String?                    @db.Uuid
  is_active                           Boolean                    @default(true)
  is_super_admin                      Boolean                    @default(false)
  wallet_balance                      Int                        @default(0)
  wallet_lifetime_earned              Int                        @default(0)
  product_tour_last_completed_version String?
  product_tour_last_skipped_version   String?
  product_tour_last_started_at        DateTime?                  @db.Timestamptz(6)
  created_at                          DateTime                   @default(now()) @db.Timestamptz(6)
  updated_at                          DateTime                   @default(now()) @db.Timestamptz(6)
  organization                        Organization?              @relation("OrganizationMembers", fields: [organization_id], references: [id], onDelete: SetNull)
  manager                             User?                      @relation("UserManager", fields: [manager_user_id], references: [id], onDelete: SetNull)
  directReports                       User[]                     @relation("UserManager")
  ownedOrganizations                  Organization[]             @relation("OrganizationOwner")
  notifications                       Notification[]
  accounts                            Account[]
  sessions                            Session[]
  invitedTeamMembers                  TeamInvitation[]           @relation("TeamInvitationInvitedBy")
  userRoles                           UserRole[]                 @relation("UserRoleUser")
  roleAssignments                     UserRole[]                 @relation("UserRoleAssignedBy")
  activityLogs                        ActivityLog[]              @relation("ActivityLogActor")
  createdIndustries                   Industry[]                 @relation("IndustryCreatedBy")
  updatedIndustries                   Industry[]                 @relation("IndustryUpdatedBy")
  createdCompanyCategories            CompanyCategory[]          @relation("CompanyCategoryCreatedBy")
  updatedCompanyCategories            CompanyCategory[]          @relation("CompanyCategoryUpdatedBy")
  assignedCompanies                   Company[]                  @relation("CompanyAssignedUser")
  referredCompanies                   Company[]                  @relation("CompanyReferredBy")
  createdContacts                     ContactPerson[]            @relation("ContactPersonCreatedBy")
  updatedContacts                     ContactPerson[]            @relation("ContactPersonUpdatedBy")
  assignedInteractions                Interaction[]              @relation("InteractionAssignedUser")
  createdInteractions                 Interaction[]              @relation("InteractionCreatedBy")
  updatedInteractions                 Interaction[]              @relation("InteractionUpdatedBy")
  assignedFollowups                   Followup[]                 @relation("FollowupAssignedUser")
  completedFollowups                  Followup[]                 @relation("FollowupCompletedBy")
  createdFollowups                    Followup[]                 @relation("FollowupCreatedBy")
  updatedFollowups                    Followup[]                 @relation("FollowupUpdatedBy")
  emailReminderLogs                   EmailReminderLog[]         @relation("EmailReminderLogUser")
  downloadedDocuments                 DocumentDownloadLog[]      @relation("DocumentDownloadLogUser")
  requestedHelpRequests               HelpRequest[]              @relation("HelpRequestRequestedBy")
  assignedHelpRequests                HelpRequest[]              @relation("HelpRequestAssignedTo")
  resolvedHelpRequests                HelpRequest[]              @relation("HelpRequestResolvedBy")
  createdHelpRequests                 HelpRequest[]              @relation("HelpRequestCreatedBy")
  updatedHelpRequests                 HelpRequest[]              @relation("HelpRequestUpdatedBy")
  helpRequestComments                 HelpRequestComment[]       @relation("HelpRequestCommentUser")
  scoringTransactions                 WalletTransaction[]        @relation("WalletTransactionUser")
  createdWalletTransactions           WalletTransaction[]        @relation("WalletTransactionCreatedBy")
  challengeProgress                   UserChallengeProgress[]    @relation("UserChallengeProgressUser")
  userStreaks                         UserStreak[]               @relation("UserStreakUser")
  rewardRedemptions                   RewardRedemption[]         @relation("RewardRedemptionUser")
  processedRewardRedemptions          RewardRedemption[]         @relation("RewardRedemptionProcessedBy")
  userBadges                          UserBadge[]                @relation("UserBadgeUser")
  awardedBadges                       UserBadge[]                @relation("UserBadgeAwardedBy")
  scoringLogs                         ScoringActivityLog[]       @relation("ScoringActivityLogUser")
  actorScoringLogs                    ScoringActivityLog[]       @relation("ScoringActivityLogActor")
  performanceTargets                  UserPerformanceTarget[]    @relation("UserPerformanceTargetUser")
  assignedPerformanceTargets          UserPerformanceTarget[]    @relation("UserPerformanceTargetAssignedBy")
  createdDocuments                    Document[]                 @relation("DocumentCreatedBy")
  updatedDocuments                    Document[]                 @relation("DocumentUpdatedBy")
  uploadedDocuments                   Document[]                 @relation("DocumentUploadedBy")

  @@index([organization_id])
  @@index([manager_user_id])
  @@map("profiles")
}

model Organization {
  id                        String                     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                      String
  slug                      String                     @unique
  company_size              String?
  owner_user_id             String                     @db.Uuid
  created_at                DateTime                   @default(now()) @db.Timestamptz(6)
  updated_at                DateTime                   @db.Timestamptz(6)
  owner                     User                       @relation("OrganizationOwner", fields: [owner_user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  members                   User[]                     @relation("OrganizationMembers")
  roles                     Role[]
  subscriptions             OrganizationSubscription[]
  notifications             Notification[]
  teamInvitations           TeamInvitation[]
  userRoles                 UserRole[]
  companies                 Company[]
  documents                 Document[]
  profileTargets            UserPerformanceTarget[]
  pipelineStages            PipelineStage[]
  activityLogs              ActivityLog[]
  industries                Industry[]
  companyCategories         CompanyCategory[]
  contactPersons            ContactPerson[]
  interactions              Interaction[]
  followups                 Followup[]
  emailReminderLogs         EmailReminderLog[]
  documentDownloadLogs      DocumentDownloadLog[]
  helpRequests              HelpRequest[]
  helpRequestComments       HelpRequestComment[]
  leadScoreRules            LeadScoreRule[]
  leadSourceScoreRules      LeadSourceScoreRule[]
  challengeTemplates        ChallengeTemplate[]
  rewardsCatalog            RewardCatalog[]
  walletTransactions        WalletTransaction[]
  userChallengeProgress     UserChallengeProgress[]
  userStreaks               UserStreak[]
  rewardRedemptions         RewardRedemption[]
  userBadges                UserBadge[]
  scoringActivityLogs       ScoringActivityLog[]

  @@map("organizations")
}

model Role {
  id              String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String           @db.Uuid
  name            String
  slug            String
  description     String?
  is_system       Boolean          @default(true)
  created_at      DateTime         @default(now()) @db.Timestamptz(6)
  updated_at      DateTime         @default(now()) @db.Timestamptz(6)
  organization    Organization     @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  userRoles       UserRole[]
  rolePermissions RolePermission[]
  teamInvitations TeamInvitation[]

  @@unique([organization_id, slug])
  @@map("roles")
}

model Permission {
  id              String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  key             String           @unique
  name            String
  description     String?
  created_at      DateTime         @default(now()) @db.Timestamptz(6)
  rolePermissions RolePermission[]

  @@map("permissions")
}

model RolePermission {
  role_id       String     @db.Uuid
  permission_id String     @db.Uuid
  created_at    DateTime   @default(now()) @db.Timestamptz(6)
  role          Role       @relation(fields: [role_id], references: [id], onDelete: Cascade)
  permission    Permission @relation(fields: [permission_id], references: [id], onDelete: Cascade)

  @@id([role_id, permission_id])
  @@map("role_permissions")
}

model UserRole {
  id              String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String       @db.Uuid
  user_id         String       @db.Uuid
  role_id         String       @db.Uuid
  assigned_by     String?      @db.Uuid
  assigned_at     DateTime     @default(now()) @db.Timestamptz(6)
  organization    Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  user            User         @relation("UserRoleUser", fields: [user_id], references: [id], onDelete: Cascade)
  role            Role         @relation(fields: [role_id], references: [id], onDelete: Cascade)
  assignedBy      User?        @relation("UserRoleAssignedBy", fields: [assigned_by], references: [id], onDelete: SetNull)

  @@unique([organization_id, user_id, role_id])
  @@map("user_roles")
}

model Notification {
  id              String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String       @db.Uuid
  user_id         String       @db.Uuid
  type            String
  title           String
  message         String
  link            String?
  is_read         Boolean      @default(false)
  read_at         DateTime?    @db.Timestamptz(6)
  created_at      DateTime     @default(now()) @db.Timestamptz(6)
  organization    Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  user            User         @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([organization_id, user_id, is_read, created_at(sort: Desc)])
  @@index([user_id, created_at(sort: Desc)])
  @@map("notifications")
}

model SubscriptionPlan {
  id                        String                     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                      String                     @unique
  slug                      String                     @unique
  description               String?
  monthly_price             Decimal                    @default(0) @db.Decimal(10, 2)
  max_users                 Int?
  max_organizations         Int                        @default(1)
  max_companies             Int?
  storage_limit_mb          Int?
  file_size_limit_mb        Int?
  custom_pipeline           Boolean                    @default(false)
  pdf_export                Boolean                    @default(false)
  csv_import                Boolean                    @default(false)
  advanced_reports          Boolean                    @default(false)
  audit_log                 Boolean                    @default(false)
  is_active                 Boolean                    @default(true)
  created_at                DateTime                   @default(now()) @db.Timestamptz(6)
  organizationSubscriptions OrganizationSubscription[]

  @@map("subscription_plans")
}

model OrganizationSubscription {
  id                       String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id          String           @unique @db.Uuid
  plan_id                  String           @db.Uuid
  status                   String           @default("trialing")
  trial_starts_at          DateTime         @default(now()) @db.Timestamptz(6)
  trial_ends_at            DateTime         @db.Timestamptz(6)
  current_period_starts_at DateTime?        @db.Timestamptz(6)
  current_period_ends_at   DateTime?        @db.Timestamptz(6)
  created_at               DateTime         @default(now()) @db.Timestamptz(6)
  updated_at               DateTime         @default(now()) @db.Timestamptz(6)
  organization             Organization     @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  plan                     SubscriptionPlan @relation(fields: [plan_id], references: [id], onDelete: Restrict)

  @@map("organization_subscriptions")
}

model TeamInvitation {
  id              String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String       @db.Uuid
  email           String
  role_id         String       @db.Uuid
  invited_by      String?      @db.Uuid
  token           String       @unique
  full_name       String?
  job_title       String?
  department      String?
  phone           String?
  status          String       @default("pending")
  expires_at      DateTime     @db.Timestamptz(6)
  accepted_at     DateTime?    @db.Timestamptz(6)
  created_at      DateTime     @default(now()) @db.Timestamptz(6)
  updated_at      DateTime     @default(now()) @db.Timestamptz(6)
  organization    Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  role            Role         @relation(fields: [role_id], references: [id], onDelete: Cascade)
  invitedBy       User?        @relation("TeamInvitationInvitedBy", fields: [invited_by], references: [id], onDelete: SetNull)

  @@index([organization_id])
  @@index([email])
  @@index([token])
  @@map("team_invitations")
}

model Company {
  id                    String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id       String       @db.Uuid
  name                  String
  industry_id           String?      @db.Uuid
  category_id           String?      @db.Uuid
  lead_source           String?
  priority              String       @default("medium")
  assigned_user_id      String?      @db.Uuid
  pipeline_stage_id     String?      @db.Uuid
  status                String       @default("active")
  phone                 String?
  whatsapp              String?
  email                 String?
  website               String?
  address               String?
  city                  String?
  country               String?
  success_rating        Int?
  lead_temperature      String       @default("warm")
  estimated_value       Decimal?     @db.Decimal(14, 2)
  expected_closing_date DateTime?    @db.Date
  notes                 String?
  created_by            String?      @db.Uuid
  updated_by            String?      @db.Uuid
  lead_score            Int          @default(0)
  referred_by_user_id   String?      @db.Uuid
  created_at            DateTime     @default(now()) @db.Timestamptz(6)
  updated_at            DateTime     @default(now()) @db.Timestamptz(6)
  organization          Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  industry              Industry?    @relation(fields: [industry_id], references: [id], onDelete: SetNull)
  category              CompanyCategory? @relation(fields: [category_id], references: [id], onDelete: SetNull)
  assignedUser          User?        @relation("CompanyAssignedUser", fields: [assigned_user_id], references: [id], onDelete: SetNull)
  pipelineStage         PipelineStage? @relation(fields: [pipeline_stage_id], references: [id], onDelete: SetNull)
  referredBy            User?        @relation("CompanyReferredBy", fields: [referred_by_user_id], references: [id], onDelete: SetNull)
  contacts              ContactPerson[]
  interactions          Interaction[]
  followups             Followup[]
  documents             Document[]
  helpRequests          HelpRequest[]
  walletTransactions    WalletTransaction[] @relation("WalletTransactionCompany")
  scoringActivityLogs   ScoringActivityLog[] @relation("ScoringActivityLogCompany")

  @@index([organization_id])
  @@index([pipeline_stage_id])
  @@index([assigned_user_id])
  @@map("companies")
}

model Document {
  id                String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id   String       @db.Uuid
  company_id        String       @db.Uuid
  contact_person_id String?      @db.Uuid
  interaction_id    String?      @db.Uuid
  followup_id       String?      @db.Uuid
  document_type     String       @default("Other")
  title             String
  description       String?
  file_name         String
  file_path         String
  file_url          String?
  file_size_mb      Decimal?     @db.Decimal
  mime_type         String?
  file_extension    String?
  status            String?      @default("submitted")
  submitted_to      String?
  submitted_at      DateTime?    @db.Timestamptz(6)
  expiry_date       DateTime?    @db.Date
  remarks           String?
  created_by        String?      @db.Uuid
  updated_by        String?      @db.Uuid
  uploaded_by       String?      @db.Uuid
  created_at        DateTime?    @default(now()) @db.Timestamptz(6)
  updated_at        DateTime?    @default(now()) @db.Timestamptz(6)
  organization      Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  company           Company      @relation(fields: [company_id], references: [id], onDelete: Cascade)
  contactPerson     ContactPerson? @relation(fields: [contact_person_id], references: [id], onDelete: SetNull)
  interaction       Interaction? @relation(fields: [interaction_id], references: [id], onDelete: SetNull)
  followup          Followup?    @relation(fields: [followup_id], references: [id], onDelete: SetNull)
  createdBy         User?        @relation("DocumentCreatedBy", fields: [created_by], references: [id], onDelete: SetNull)
  updatedBy         User?        @relation("DocumentUpdatedBy", fields: [updated_by], references: [id], onDelete: SetNull)
  uploadedBy        User?        @relation("DocumentUploadedBy", fields: [uploaded_by], references: [id], onDelete: SetNull)
  downloadLogs      DocumentDownloadLog[]
  helpRequests      HelpRequest[]

  @@index([organization_id])
  @@index([organization_id, status, created_at(sort: Desc)])
  @@index([organization_id, company_id, created_at(sort: Desc)])
  @@map("documents")
}

model PipelineStage {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String   @db.Uuid
  name            String
  slug            String
  position        Int
  probability     Int      @default(0)
  is_won          Boolean  @default(false)
  is_lost         Boolean  @default(false)
  is_active       Boolean  @default(true)
  color           String   @default("#0f766e")
  created_at      DateTime @default(now()) @db.Timestamptz(6)
  updated_at      DateTime @default(now()) @db.Timestamptz(6)
  organization    Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  companies        Company[]

  @@unique([organization_id, slug])
  @@unique([organization_id, position])
  @@map("pipeline_stages")
}

model ActivityLog {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String   @db.Uuid
  actor_user_id   String?  @db.Uuid
  action          String
  entity_type     String?
  entity_id       String?  @db.Uuid
  metadata        Json     @default("{}")
  created_at      DateTime @default(now()) @db.Timestamptz(6)
  organization    Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  actorUser       User?    @relation("ActivityLogActor", fields: [actor_user_id], references: [id], onDelete: SetNull)

  @@map("activity_logs")
}

model Industry {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String   @db.Uuid
  name            String
  description     String?
  status          String   @default("active")
  created_by      String?  @db.Uuid
  updated_by      String?  @db.Uuid
  created_at      DateTime @default(now()) @db.Timestamptz(6)
  updated_at      DateTime @default(now()) @db.Timestamptz(6)
  organization    Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  createdBy       User?    @relation("IndustryCreatedBy", fields: [created_by], references: [id], onDelete: SetNull)
  updatedBy       User?    @relation("IndustryUpdatedBy", fields: [updated_by], references: [id], onDelete: SetNull)
  companies       Company[]

  @@index([organization_id])
  @@unique([organization_id, name])
  @@map("industries")
}

model CompanyCategory {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String   @db.Uuid
  name            String
  code            String
  description     String?
  priority_level  Int      @default(3)
  status          String   @default("active")
  created_by      String?  @db.Uuid
  updated_by      String?  @db.Uuid
  created_at      DateTime @default(now()) @db.Timestamptz(6)
  updated_at      DateTime @default(now()) @db.Timestamptz(6)
  organization    Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  createdBy       User?    @relation("CompanyCategoryCreatedBy", fields: [created_by], references: [id], onDelete: SetNull)
  updatedBy       User?    @relation("CompanyCategoryUpdatedBy", fields: [updated_by], references: [id], onDelete: SetNull)
  companies       Company[]

  @@index([organization_id])
  @@unique([organization_id, code])
  @@map("company_categories")
}

model ContactPerson {
  id                       String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id          String   @db.Uuid
  company_id               String   @db.Uuid
  name                     String
  designation              String?
  department               String?
  mobile                   String?
  whatsapp                 String?
  email                    String?
  linkedin                 String?
  decision_role            String?
  relationship_level       String?
  preferred_contact_method String?
  remarks                  String?
  is_primary               Boolean  @default(false)
  status                   String   @default("active")
  created_by               String?  @db.Uuid
  updated_by               String?  @db.Uuid
  created_at               DateTime @default(now()) @db.Timestamptz(6)
  updated_at               DateTime @default(now()) @db.Timestamptz(6)
  organization             Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  company                  Company @relation(fields: [company_id], references: [id], onDelete: Cascade)
  createdBy                User?    @relation("ContactPersonCreatedBy", fields: [created_by], references: [id], onDelete: SetNull)
  updatedBy                User?    @relation("ContactPersonUpdatedBy", fields: [updated_by], references: [id], onDelete: SetNull)
  interactions             Interaction[]
  followups                Followup[]
  documents                Document[]
  helpRequests             HelpRequest[]

  @@index([organization_id])
  @@index([company_id])
  @@map("contact_persons")
}

model Interaction {
  id                   String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id      String    @db.Uuid
  company_id           String    @db.Uuid
  contact_person_id    String?   @db.Uuid
  assigned_user_id     String?   @db.Uuid
  interaction_type     String    @default("Phone Call")
  meeting_datetime     DateTime  @default(now()) @db.Timestamptz(6)
  location             String?
  online_meeting_link  String?
  discussion_details   String
  client_requirement   String?
  pain_point           String?
  proposed_solution    String?
  budget_discussion    String?
  competitor_mentioned String?
  decision_timeline    String?
  success_rating       Int?
  lead_temperature     String?
  next_action          String?
  next_followup_at     DateTime? @db.Timestamptz(6)
  need_help            Boolean   @default(false)
  internal_note        String?
  status               String    @default("active")
  created_by           String?   @db.Uuid
  updated_by           String?   @db.Uuid
  created_at           DateTime  @default(now()) @db.Timestamptz(6)
  updated_at           DateTime  @default(now()) @db.Timestamptz(6)
  organization         Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  company              Company @relation(fields: [company_id], references: [id], onDelete: Cascade)
  contactPerson        ContactPerson? @relation(fields: [contact_person_id], references: [id], onDelete: SetNull)
  assignedUser         User?    @relation("InteractionAssignedUser", fields: [assigned_user_id], references: [id], onDelete: SetNull)
  createdBy            User?    @relation("InteractionCreatedBy", fields: [created_by], references: [id], onDelete: SetNull)
  updatedBy            User?    @relation("InteractionUpdatedBy", fields: [updated_by], references: [id], onDelete: SetNull)
  followups            Followup[]
  documents            Document[]
  helpRequests         HelpRequest[]

  @@index([organization_id])
  @@index([company_id])
  @@index([contact_person_id])
  @@index([meeting_datetime])
  @@map("interactions")
}

model Followup {
  id                      String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id         String    @db.Uuid
  company_id              String    @db.Uuid
  contact_person_id       String?   @db.Uuid
  interaction_id          String?   @db.Uuid
  assigned_user_id        String?   @db.Uuid
  followup_type           String    @default("Phone Call")
  title                   String
  description             String?
  scheduled_at            DateTime  @db.Timestamptz(6)
  reminder_before_minutes Int?      @default(60)
  status                  String    @default("pending")
  priority                String    @default("medium")
  completed_at            DateTime? @db.Timestamptz(6)
  completed_by            String?   @db.Uuid
  rescheduled_from        DateTime? @db.Timestamptz(6)
  cancelled_reason        String?
  created_by              String    @db.Uuid
  updated_by              String    @db.Uuid
  created_at              DateTime? @default(now()) @db.Timestamptz(6)
  updated_at              DateTime? @default(now()) @db.Timestamptz(6)
  organization            Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  company                 Company @relation(fields: [company_id], references: [id], onDelete: Cascade)
  contactPerson           ContactPerson? @relation(fields: [contact_person_id], references: [id], onDelete: SetNull)
  interaction             Interaction? @relation(fields: [interaction_id], references: [id], onDelete: SetNull)
  assignedUser            User?    @relation("FollowupAssignedUser", fields: [assigned_user_id], references: [id], onDelete: SetNull)
  completedBy             User?    @relation("FollowupCompletedBy", fields: [completed_by], references: [id], onDelete: SetNull)
  createdBy               User     @relation("FollowupCreatedBy", fields: [created_by], references: [id], onDelete: Cascade)
  updatedBy               User     @relation("FollowupUpdatedBy", fields: [updated_by], references: [id], onDelete: Cascade)
  emailReminderLogs       EmailReminderLog[]
  documents               Document[]
  helpRequests            HelpRequest[]
  walletTransactions      WalletTransaction[] @relation("WalletTransactionFollowup")
  scoringActivityLogs     ScoringActivityLog[] @relation("ScoringActivityLogFollowup")

  @@map("followups")
}

model EmailReminderLog {
