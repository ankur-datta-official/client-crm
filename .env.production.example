NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://crm.mugnee.com
NEXTAUTH_URL=https://crm.mugnee.com
AUTH_SECRET=replace-with-secure-random-secret
AUTH_PROVIDER=nextauth
NEXT_PUBLIC_AUTH_PROVIDER=nextauth
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@127.0.0.1:5432/crm?schema=public
SUPABASE_SOURCE_DATABASE_URL=
SMTP_HOST=mugneekh.com
SMTP_PORT=587
SMTP_USER=no-reply@mugneekh.com
SMTP_PASSWORD=YOUR_SMTP_PASSWORD
SMTP_FROM=Client CRM <no-reply@mugneekh.com>
UPLOAD_DIR=/home/crm.mugnee.com/public_html/public/uploads
PRIVATE_UPLOAD_DIR=/home/crm.mugnee.com/public_html/storage/private
TEMP_UPLOAD_DIR=/home/crm.mugnee.com/public_html/storage/tmp
PUBLIC_UPLOAD_BASE_URL=https://crm.mugnee.com
MAX_UPLOAD_SIZE_MB=25
