NODE_ENV=production

# App URL
NEXT_PUBLIC_APP_URL=https://crm.example.com

# Primary PostgreSQL database for Prisma
DATABASE_URL=postgresql://crm_app:replace-with-strong-password@127.0.0.1:5432/crm?schema=public

# Optional one-time source connection for live Supabase -> PostgreSQL data migration.
# Remove after the migration is finished.
SUPABASE_SOURCE_DATABASE_URL="postgresql://postgres.lhktyxsneixgozodpwsl:MugneeDB%402026%23@aws-1-ap-southeast-2.pooler.supabase.com:5432/postgres"

# Better Auth
BETTER_AUTH_SECRET=replace-with-a-long-random-secret
BETTER_AUTH_URL=https://crm.example.com

# Auth.js / NextAuth rollback settings
AUTH_SECRET=replace-with-a-long-random-secret
NEXTAUTH_URL=https://crm.example.com

# Auth migration toggle
# Use Better Auth as the primary production auth provider.
AUTH_PROVIDER=betterauth
NEXT_PUBLIC_AUTH_PROVIDER=betterauth

# VPS/local storage
UPLOAD_DIR=/var/www/saas-crm/public/uploads
PRIVATE_UPLOAD_DIR=/var/www/saas-crm/storage/private
TEMP_UPLOAD_DIR=/var/www/saas-crm/storage/tmp
PUBLIC_UPLOAD_BASE_URL=https://crm.example.com
MAX_UPLOAD_SIZE_MB=25

# Email / signup OTP / cron
REMINDER_EMAIL_ENABLED=false
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
# SMTP is required if you want registration OTP and invitation emails to be delivered.
CRON_SECRET=replace-with-a-random-cron-secret
