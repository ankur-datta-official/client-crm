NODE_ENV=development

NEXT_PUBLIC_APP_URL=https://your-app.example.com

# Server-only PostgreSQL for Prisma. Never expose this with NEXT_PUBLIC_.
DATABASE_URL=postgresql://postgres:your-password@localhost:5432/crm?schema=public

# One-time source connection for live Supabase -> PostgreSQL data migration.
# Do not keep this around after migration is done.
SUPABASE_SOURCE_DATABASE_URL=

# Parallel auth migration toggle.
# Keep both values aligned while testing client login/logout flows.
AUTH_PROVIDER=betterauth
NEXT_PUBLIC_AUTH_PROVIDER=betterauth

# Better Auth local settings
BETTER_AUTH_SECRET=replace-with-a-long-random-secret
BETTER_AUTH_URL=http://localhost:3000

# Auth.js / NextAuth rollback settings
AUTH_SECRET=replace-with-a-long-random-secret
NEXTAUTH_URL=http://localhost:3000

# VPS/local storage layout
# Public uploads can live under public/uploads if you add any public file features later.
UPLOAD_DIR=public/uploads
PRIVATE_UPLOAD_DIR=uploads/private
TEMP_UPLOAD_DIR=uploads/tmp
PUBLIC_UPLOAD_BASE_URL=http://localhost:3000
MAX_UPLOAD_SIZE_MB=25

# Email reminder, signup OTP, and cron settings
REMINDER_EMAIL_ENABLED=false
RESEND_API_KEY=
RESEND_FROM_EMAIL=
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
# Resend is preferred for OTP, reset, invite, and approval emails. SMTP remains available as a fallback.
CRON_SECRET=your-random-cron-secret
