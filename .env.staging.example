NODE_ENV=production

# Private staging URL or temporary host mapping on the Ubuntu server
NEXT_PUBLIC_APP_URL=https://staging.crm.mugnee.com

# Isolated staging PostgreSQL database
DATABASE_URL=postgresql://crm_staging:replace-with-strong-password@127.0.0.1:5432/crm_staging?schema=public

# Leave blank unless you are actively importing legacy data into staging
SUPABASE_SOURCE_DATABASE_URL=

# Better Auth
BETTER_AUTH_SECRET=replace-with-a-long-random-secret
BETTER_AUTH_URL=https://staging.crm.mugnee.com

# Auth.js / NextAuth rollback settings
AUTH_SECRET=replace-with-a-long-random-secret
NEXTAUTH_URL=https://staging.crm.mugnee.com

# Auth provider
AUTH_PROVIDER=betterauth
NEXT_PUBLIC_AUTH_PROVIDER=betterauth

# Staging storage roots
UPLOAD_DIR=/var/www/saas-crm-staging/public/uploads
PRIVATE_UPLOAD_DIR=/var/www/saas-crm-staging/storage/private
TEMP_UPLOAD_DIR=/var/www/saas-crm-staging/storage/tmp
PUBLIC_UPLOAD_BASE_URL=https://staging.crm.mugnee.com
MAX_UPLOAD_SIZE_MB=25

# Email / signup OTP / cron
REMINDER_EMAIL_ENABLED=false
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
CRON_SECRET=replace-with-a-random-cron-secret
